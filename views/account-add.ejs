<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - 王者荣耀英雄统计</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container mt-4">
    <div class="row justify-content-center">
      <div class="col-md-6">
        <div class="card">
          <div class="card-header">
            <h4 class="mb-0">添加游戏账号</h4>
          </div>
          <div class="card-body">
            <% if (error) { %>
              <div class="alert alert-danger"><%= error %></div>
            <% } %>
            
            <form action="/accounts/add" method="POST">
              <div class="mb-3">
                <label for="name" class="form-label">账号名称</label>
                <input type="text" class="form-control" id="name" name="name" 
                       placeholder="给这个账号起个名字" required>
              </div>
              
              <div class="mb-3">
                <label class="form-label">登录方式</label>
                <div class="d-flex gap-3">
                  <div class="form-check">
                    <input class="form-check-input" type="radio" name="loginType" 
                           id="loginTypeQQ" value="qq" checked>
                    <label class="form-check-label" for="loginTypeQQ">
                      QQ登录
                    </label>
                  </div>
                  <div class="form-check">
                    <input class="form-check-input" type="radio" name="loginType" 
                           id="loginTypeWechat" value="wechat">
                    <label class="form-check-label" for="loginTypeWechat">
                      微信登录
                    </label>
                  </div>
                </div>
              </div>
              
              <div class="mb-3">
                <label class="form-label">设备类型</label>
                <div class="d-flex gap-3">
                  <div class="form-check">
                    <input class="form-check-input" type="radio" name="platform" 
                           id="platformAndroid" value="android" checked>
                    <label class="form-check-label" for="platformAndroid">
                      安卓
                    </label>
                  </div>
                  <div class="form-check">
                    <input class="form-check-input" type="radio" name="platform" 
                           id="platformIOS" value="ios">
                    <label class="form-check-label" for="platformIOS">
                      苹果
                    </label>
                  </div>
                </div>
              </div>
              
              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">添加账号</button>
                <a href="/dashboard" class="btn btn-outline-secondary">取消</a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
