<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - 王者荣耀英雄统计</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2><%= account.name %></h2>
        <p class="text-muted mb-0">
          <%= account.loginType === 'qq' ? 'QQ登录' : '微信登录' %> | 
          <%= account.platform === 'android' ? '安卓' : '苹果' %>
        </p>
      </div>
      <a href="/dashboard" class="btn btn-outline-secondary">返回账号列表</a>
    </div>

    <!-- 添加区服表单 -->
    <div class="card mb-4">
      <div class="card-header">
        <h5 class="mb-0">添加区服</h5>
      </div>
      <div class="card-body">
        <form action="/accounts/<%= account.id %>/regions/add" method="POST" class="row g-3">
          <div class="col-md-8">
            <input type="text" class="form-control" name="regionName" 
                   placeholder="输入区服名称，如：手Q1区 王者独尊" required>
          </div>
          <div class="col-md-4">
            <button type="submit" class="btn btn-primary w-100">添加区服</button>
          </div>
        </form>
        <small class="text-muted mt-2 d-block">
          提示：可以自定义输入任意区服名称，系统会自动为新角色添加默认英雄（亚瑟、妲己、后羿、安琪拉、元流之子×5）
        </small>
      </div>
    </div>

    <!-- 区服列表 -->
    <h4 class="mb-3">我的区服</h4>
    <% if (regions.length === 0) { %>
      <div class="alert alert-info">
        还没有添加区服，请在上方添加
      </div>
    <% } else { %>
      <div class="row">
        <% regions.forEach(region => { %>
          <div class="col-md-6 col-lg-4 mb-3">
            <div class="card h-100">
              <div class="card-body">
                <h5 class="card-title"><%= region.name %></h5>
                <p class="card-text text-muted">
                  创建时间：<%= new Date(region.createdAt).toLocaleDateString() %>
                </p>
                <div class="d-flex gap-2">
                  <a href="/regions/<%= region.id %>/heroes" class="btn btn-primary btn-sm flex-fill">
                    管理英雄
                  </a>
                  <form action="/regions/<%= region.id %>/delete" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-danger btn-sm" 
                            onclick="return confirm('确定要删除这个区服吗？相关的英雄数据也会被删除。')">
                      删除
                    </button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
