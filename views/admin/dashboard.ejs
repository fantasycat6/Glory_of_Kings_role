<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - 管理员后台</title>
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="alternate icon" href="/favicon.png">
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container-fluid mt-4">
    <div class="row">
      <!-- 侧边栏 -->
      <div class="col-md-2">
        <div class="list-group">
          <a href="/admin" class="list-group-item list-group-item-action active">
            <i class="bi bi-speedometer2 me-2"></i>概览
          </a>
          <a href="/admin/users" class="list-group-item list-group-item-action">
            <i class="bi bi-people me-2"></i>用户管理
          </a>
          <a href="/admin/heroes" class="list-group-item list-group-item-action">
            <i class="bi bi-person-badge me-2"></i>英雄管理
          </a>
          <a href="/admin/backup" class="list-group-item list-group-item-action">
            <i class="bi bi-database me-2"></i>数据备份
          </a>
        </div>
      </div>
      
      <!-- 主内容 -->
      <div class="col-md-10">
        <h3 class="mb-4">管理员后台</h3>
        
        <!-- 统计卡片 -->
        <div class="row mb-4">
          <div class="col-md-4">
            <div class="card bg-primary text-white">
              <div class="card-body">
                <h5 class="card-title">总用户数</h5>
                <h2 class="mb-0"><%= users.length %></h2>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card bg-success text-white">
              <div class="card-body">
                <h5 class="card-title">英雄总数</h5>
                <h2 class="mb-0"><%= heroes.length %></h2>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card bg-info text-white">
              <div class="card-body">
                <h5 class="card-title">管理员数</h5>
                <h2 class="mb-0"><%= users.filter(u => u.isAdmin).length %></h2>
              </div>
            </div>
          </div>
        </div>

        <!-- 快捷入口 -->
        <div class="row">
          <div class="col-md-6">
            <div class="card">
              <div class="card-header">
                <h5 class="mb-0">快捷入口</h5>
              </div>
              <div class="card-body">
                <div class="d-grid gap-2">
                  <a href="/admin/users" class="btn btn-outline-primary">
                    <i class="bi bi-people me-2"></i>用户管理
                  </a>
                  <a href="/admin/heroes" class="btn btn-outline-primary">
                    <i class="bi bi-person-badge me-2"></i>英雄管理
                  </a>
                  <a href="/admin/backup" class="btn btn-outline-success">
                    <i class="bi bi-database me-2"></i>数据备份
                  </a>
                </div>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card">
              <div class="card-header">
                <h5 class="mb-0">系统信息</h5>
              </div>
              <div class="card-body">
                <p class="mb-1"><strong>英雄数据版本：</strong> 2026年4月</p>
                <p class="mb-1"><strong>英雄总数：</strong> <%= heroes.length %> 位</p>
                <p class="mb-1"><strong>默认英雄：</strong> 9 个</p>
                <p class="mb-0"><strong>区服类型：</strong> 用户自定义</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
