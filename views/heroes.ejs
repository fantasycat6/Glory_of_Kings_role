<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - 王者荣耀英雄统计</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <style>
    .hero-card {
      cursor: pointer;
      transition: all 0.2s;
      user-select: none;
    }
    .hero-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }
    .hero-card.owned {
      border-color: #28a745;
      background-color: #f8fff8;
    }
    .hero-card.owned .owned-badge {
      display: inline-block;
    }
    .owned-badge {
      display: none;
      position: absolute;
      top: 0;
      right: 0;
      font-size: 0.65rem;
      padding: 0.2em 0.4em;
      border-radius: 0 0.25rem 0 0.25rem;
      z-index: 10;
    }
    .stats-card {
      position: sticky;
      top: 20px;
    }
    .role-filter .btn {
      margin-right: 5px;
      margin-bottom: 5px;
    }
    .search-box {
      max-width: 300px;
    }
    /* 框选高亮 */
    .hero-card.drag-highlight {
      border-color: #0d6efd;
      box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.3);
    }
    /* 多选模式选中状态 */
    .hero-card.selected-temp {
      border-color: #0d6efd;
      background-color: #e7f1ff;
    }
    /* 禁用文本选择 */
    #heroGrid {
      user-select: none;
    }
    /* 卡片图片容器 */
    .hero-card .card-body > div:first-child {
      position: relative;
      display: inline-block;
    }
  </style>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container-fluid mt-4">
    <div class="row">
      <!-- 左侧：英雄列表 -->
      <div class="col-lg-9">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div>
            <h3><%= region.name %></h3>
            <p class="text-muted mb-0">
              <%= account.name %> | 
              <%= account.loginType === 'qq' ? 'QQ' : '微信' %> | 
              <%= account.platform === 'android' ? '安卓' : '苹果' %>
            </p>
          </div>
          <a href="/accounts/<%= account.id %>" class="btn btn-outline-secondary">返回区服列表</a>
        </div>

        <!-- 搜索和筛选 -->
        <div class="card mb-3">
          <div class="card-body">
            <div class="row align-items-center">
              <div class="col-md-4 mb-2 mb-md-0">
                <input type="text" class="form-control" id="searchInput" 
                       placeholder="搜索英雄名称...">
              </div>
              <div class="col-md-8">
                <div class="role-filter">
                  <button class="btn btn-sm btn-outline-primary active" data-role="all">全部</button>
                  <button class="btn btn-sm btn-outline-primary" data-role="坦克">坦克</button>
                  <button class="btn btn-sm btn-outline-primary" data-role="战士">战士</button>
                  <button class="btn btn-sm btn-outline-primary" data-role="刺客">刺客</button>
                  <button class="btn btn-sm btn-outline-primary" data-role="法师">法师</button>
                  <button class="btn btn-sm btn-outline-primary" data-role="射手">射手</button>
                  <button class="btn btn-sm btn-outline-primary" data-role="辅助">辅助</button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 批量操作栏 -->
        <div class="card mb-3 bg-light" id="batchActions" style="display: none;">
          <div class="card-body py-2">
            <div class="d-flex align-items-center flex-wrap gap-2">
              <span class="text-muted">多选模式：</span>
              <button class="btn btn-sm btn-success" onclick="batchSelect(true)">
                <i class="bi bi-check-all"></i> 全选
              </button>
              <button class="btn btn-sm btn-warning" onclick="batchSelect(false)">
                <i class="bi bi-x-circle"></i> 取消
              </button>
              <button class="btn btn-sm btn-primary" onclick="confirmBatchSelection()">
                <i class="bi bi-check-lg"></i> 确认
              </button>
              <button class="btn btn-sm btn-secondary" onclick="cancelBatchSelection()">
                <i class="bi bi-x-lg"></i> 退出
              </button>
              <span class="badge bg-primary ms-auto" id="selectedCount">已选择: 0</span>
            </div>
            <div class="mt-2 text-muted small">
              <i class="bi bi-info-circle"></i> 提示：拖动鼠标框选英雄，再次框选已选中英雄可取消
            </div>
          </div>
        </div>

        <!-- 多选模式入口 -->
        <div class="card mb-3" id="normalActions">
          <div class="card-body py-2 d-flex justify-content-between align-items-center">
            <span class="text-muted">点击英雄卡片切换拥有状态</span>
            <button class="btn btn-sm btn-outline-primary" onclick="enterMultiSelectMode()">
              <i class="bi bi-check2-square"></i> 多选
            </button>
          </div>
        </div>

        <!-- 英雄网格 -->
        <div class="row" id="heroGrid">
          <% heroes.forEach(hero => { 
            const isOwned = ownedHeroNames.includes(hero.name);
            const heroImage = heroImages[hero.name];
          %>
            <div class="col-6 col-sm-4 col-md-3 col-lg-2 mb-3 hero-item" 
                 data-name="<%= hero.name %>" 
                 data-role="<%= hero.role %>">
              <div class="card hero-card <%= isOwned ? 'owned' : '' %>" 
                   data-hero-name="<%= hero.name %>">
                <div class="card-body text-center p-2 position-relative">
                  <span class="badge bg-success owned-badge">已拥有</span>
                  <div class="mb-2">
                    <% if (heroImage) { %>
                      <a href="<%= heroImage.url %>" target="_blank" onclick="event.stopPropagation();">
                        <img src="<%= heroImage.image %>" alt="<%= hero.name %>" 
                             class="rounded-circle" style="width: 60px; height: 60px; object-fit: cover;">
                      </a>
                    <% } else { %>
                      <div class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center" 
                           style="width: 60px; height: 60px;">
                        <span class="text-white"><%= hero.name.charAt(0) %></span>
                      </div>
                    <% } %>
                  </div>
                  <h6 class="card-title mb-1"><%= hero.name %></h6>
                  <small class="text-muted"><%= hero.role %></small>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      </div>

      <!-- 右侧：统计信息 -->
      <div class="col-lg-3">
        <div class="card stats-card">
          <div class="card-header">
            <h5 class="mb-0">收集统计</h5>
          </div>
          <div class="card-body">
            <div class="text-center mb-3">
              <h2 class="mb-0">
                <span id="ownedCount"><%= stats.owned %></span> / <%= stats.total %>
              </h2>
              <p class="text-muted">已收集 / 总数</p>
            </div>
            
            <div class="progress mb-3">
              <div class="progress-bar bg-success" role="progressbar" 
                   style="width: <%= stats.percentage %>%" 
                   id="progressBar">
                <%= stats.percentage %>%
              </div>
            </div>

            <h6 class="mb-2">按职业分布</h6>
            <div id="roleStats">
              <% Object.entries(stats.byRole).forEach(([role, data]) => { %>
                <div class="d-flex justify-content-between mb-1">
                  <span><%= role %></span>
                  <span><%= data.owned %> / <%= data.total %></span>
                </div>
              <% }); %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // 切换英雄拥有状态
    async function toggleHero(heroName, element) {
      const isOwned = element.classList.contains('owned');
      
      try {
        const response = await fetch(`/regions/<%= region.id %>/heroes/update`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
          },
          body: `heroName=${encodeURIComponent(heroName)}&owned=${!isOwned}`
        });
        
        const data = await response.json();
        
        if (data.success) {
          // 切换owned类并清除内联样式，让CSS类控制显示
          element.classList.toggle('owned');
          element.style.borderColor = '';
          element.style.backgroundColor = '';
          updateStats(data.stats);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('操作失败，请重试');
      }
    }

    // 更新统计信息
    function updateStats(stats) {
      document.getElementById('ownedCount').textContent = stats.owned;
      document.getElementById('progressBar').style.width = stats.percentage + '%';
      document.getElementById('progressBar').textContent = stats.percentage + '%';
      
      // 更新职业分布
      const roleStatsHtml = Object.entries(stats.byRole).map(([role, data]) => {
        return `
          <div class="d-flex justify-content-between mb-1">
            <span>${role}</span>
            <span>${data.owned} / ${data.total}</span>
          </div>
        `;
      }).join('');
      document.getElementById('roleStats').innerHTML = roleStatsHtml;
    }

    // 搜索功能
    document.getElementById('searchInput').addEventListener('input', function(e) {
      const query = e.target.value.toLowerCase();
      document.querySelectorAll('.hero-item').forEach(item => {
        const name = item.dataset.name.toLowerCase();
        if (name.includes(query)) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });

    // 职业筛选
    document.querySelectorAll('.role-filter .btn').forEach(btn => {
      btn.addEventListener('click', function() {
        // 更新按钮状态
        document.querySelectorAll('.role-filter .btn').forEach(b => {
          b.classList.remove('active');
        });
        this.classList.add('active');
        
        const role = this.dataset.role;
        document.querySelectorAll('.hero-item').forEach(item => {
          if (role === 'all' || item.dataset.role.includes(role)) {
            item.style.display = '';
          } else {
            item.style.display = 'none';
          }
        });
        updateSelectedCount();
      });
    });

    // 获取当前可见的英雄
    function getVisibleHeroes() {
      return Array.from(document.querySelectorAll('.hero-item')).filter(item => {
        return item.style.display !== 'none';
      });
    }

    // 获取当前可见且未拥有的英雄
    function getVisibleNotOwnedHeroes() {
      return getVisibleHeroes().filter(item => {
        return !item.querySelector('.hero-card').classList.contains('owned');
      });
    }

    // 获取当前可见且已拥有的英雄
    function getVisibleOwnedHeroes() {
      return getVisibleHeroes().filter(item => {
        return item.querySelector('.hero-card').classList.contains('owned');
      });
    }

    // 多选模式状态
    let isMultiSelectMode = false;
    let tempSelection = new Set(); // 临时选中的英雄
    let isDragging = false;
    let dragStartHero = null;
    let dragEndHero = null;
    let dragHandlersAttached = false; // 跟踪拖拽事件是否已绑定

    // 进入多选模式
    function enterMultiSelectMode(initialHero = null) {
      isMultiSelectMode = true;
      tempSelection.clear();
      
      // 将当前已拥有的英雄加入临时选择
      document.querySelectorAll('.hero-card.owned').forEach(card => {
        const heroName = card.closest('.hero-item').dataset.name;
        tempSelection.add(heroName);
      });
      
      // 如果有初始英雄，切换它的选中状态
      if (initialHero) {
        toggleTempSelection(initialHero);
      }
      
      // 显示批量操作栏，隐藏正常操作栏
      document.getElementById('batchActions').style.display = 'block';
      document.getElementById('normalActions').style.display = 'none';
      
      // 启用框选功能
      enableDragSelection();
      
      // 更新UI显示
      updateMultiSelectUI();
    }

    // 退出多选模式
    function cancelBatchSelection() {
      isMultiSelectMode = false;
      tempSelection.clear();
      document.getElementById('batchActions').style.display = 'none';
      document.getElementById('normalActions').style.display = 'block';
      
      // 禁用框选功能
      disableDragSelection();
      
      // 清理所有临时样式，恢复原始状态
      restoreOriginalState();
    }
    
    // 恢复原始状态（清理多选模式的临时样式）
    function restoreOriginalState() {
      document.querySelectorAll('.hero-card').forEach(card => {
        // 移除临时选择样式
        card.classList.remove('selected-temp', 'drag-highlight');
        card.style.borderColor = '';
        card.style.backgroundColor = '';
        
        // 根据是否已拥有恢复正确的样式
        const isOwned = card.classList.contains('owned');
        if (isOwned) {
          card.style.borderColor = '#28a745';
          card.style.backgroundColor = '#f8fff8';
        }
      });
      
      // 更新计数显示
      updateSelectedCount();
    }

    // 拖拽相关事件处理函数引用（用于后续移除）
    let dragStartHandler, dragMoveHandler, dragEndHandler;
    
    // 启用长按框选
    function enableDragSelection() {
      if (dragHandlersAttached) return; // 避免重复绑定
      
      const heroGrid = document.getElementById('heroGrid');
      let startX, startY;
      let selectionBox = null;
      
      // 定义事件处理函数
      dragStartHandler = function(e) {
        if (!isMultiSelectMode) return;
        
        // 如果点击的是英雄卡片，不启动框选（让单击事件处理）
        if (e.target.closest('.hero-card')) return;
        
        e.preventDefault();
        isDragging = true;
        
        // 创建选择框
        selectionBox = document.createElement('div');
        selectionBox.className = 'selection-box';
        selectionBox.style.cssText = `
          position: fixed;
          border: 2px dashed #0d6efd;
          background: rgba(13, 110, 253, 0.1);
          pointer-events: none;
          z-index: 1000;
        `;
        document.body.appendChild(selectionBox);
        
        startX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
        startY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;
        
        updateSelectionBox(startX, startY, startX, startY);
        
        document.addEventListener('mousemove', dragMoveHandler);
        document.addEventListener('touchmove', dragMoveHandler, { passive: false });
        document.addEventListener('mouseup', dragEndHandler);
        document.addEventListener('touchend', dragEndHandler);
      };
      
      dragMoveHandler = function(e) {
        if (!isDragging || !selectionBox) return;
        
        e.preventDefault();
        const currentX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
        const currentY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;
        
        updateSelectionBox(startX, startY, currentX, currentY);
        
        // 高亮框选区域内的英雄
        highlightSelectedHeroes(startX, startY, currentX, currentY);
      };
      
      dragEndHandler = function(e) {
        if (!isDragging) return;
        
        isDragging = false;
        
        // 应用选择
        if (selectionBox) {
          const endX = e.type.includes('touch') ? e.changedTouches[0].clientX : e.clientX;
          const endY = e.type.includes('touch') ? e.changedTouches[0].clientY : e.clientY;
          applySelection(startX, startY, endX, endY);
          
          selectionBox.remove();
          selectionBox = null;
        }
        
        document.removeEventListener('mousemove', dragMoveHandler);
        document.removeEventListener('touchmove', dragMoveHandler);
        document.removeEventListener('mouseup', dragEndHandler);
        document.removeEventListener('touchend', dragEndHandler);
      };
      
      function updateSelectionBox(x1, y1, x2, y2) {
        const left = Math.min(x1, x2);
        const top = Math.min(y1, y2);
        const width = Math.abs(x2 - x1);
        const height = Math.abs(y2 - y1);
        
        selectionBox.style.left = left + 'px';
        selectionBox.style.top = top + 'px';
        selectionBox.style.width = width + 'px';
        selectionBox.style.height = height + 'px';
      }
      
      function highlightSelectedHeroes(x1, y1, x2, y2) {
        const left = Math.min(x1, x2);
        const top = Math.min(y1, y2);
        const right = Math.max(x1, x2);
        const bottom = Math.max(y1, y2);
        
        document.querySelectorAll('.hero-item').forEach(item => {
          const rect = item.getBoundingClientRect();
          const itemCenterX = rect.left + rect.width / 2;
          const itemCenterY = rect.top + rect.height / 2;
          
          // 检查英雄中心点是否在框选区域内
          if (itemCenterX >= left && itemCenterX <= right && 
              itemCenterY >= top && itemCenterY <= bottom) {
            item.querySelector('.hero-card').classList.add('drag-highlight');
          } else {
            item.querySelector('.hero-card').classList.remove('drag-highlight');
          }
        });
      }
      
      function applySelection(x1, y1, x2, y2) {
        const left = Math.min(x1, x2);
        const top = Math.min(y1, y2);
        const right = Math.max(x1, x2);
        const bottom = Math.max(y1, y2);
        
        // 获取框选区域内的所有英雄
        const selectedInBox = [];
        document.querySelectorAll('.hero-item').forEach(item => {
          const rect = item.getBoundingClientRect();
          const itemCenterX = rect.left + rect.width / 2;
          const itemCenterY = rect.top + rect.height / 2;
          
          if (itemCenterX >= left && itemCenterX <= right && 
              itemCenterY >= top && itemCenterY <= bottom) {
            selectedInBox.push(item.dataset.name);
          }
          
          item.querySelector('.hero-card').classList.remove('drag-highlight');
        });
        
        // 切换选择：已选中的取消，未选中的添加
        selectedInBox.forEach(name => {
          if (tempSelection.has(name)) {
            tempSelection.delete(name);
          } else {
            tempSelection.add(name);
          }
        });
        
        updateMultiSelectUI();
      }
      
      // 绑定事件
      heroGrid.addEventListener('mousedown', dragStartHandler);
      heroGrid.addEventListener('touchstart', dragStartHandler, { passive: false });
      dragHandlersAttached = true;
    }
    
    // 禁用框选
    function disableDragSelection() {
      if (!dragHandlersAttached) return;
      
      const heroGrid = document.getElementById('heroGrid');
      heroGrid.removeEventListener('mousedown', dragStartHandler);
      heroGrid.removeEventListener('touchstart', dragStartHandler);
      
      dragHandlersAttached = false;
    }

    // 确认批量选择
    async function confirmBatchSelection() {
      const heroesToAdd = [];
      const heroesToRemove = [];
      
      document.querySelectorAll('.hero-item').forEach(item => {
        const heroName = item.dataset.name;
        const isOwned = item.querySelector('.hero-card').classList.contains('owned');
        const isSelected = tempSelection.has(heroName);
        
        if (isSelected && !isOwned) {
          heroesToAdd.push(heroName);
        } else if (!isSelected && isOwned) {
          heroesToRemove.push(heroName);
        }
      });
      
      // 执行添加
      if (heroesToAdd.length > 0) {
        await batchUpdateHeroes(heroesToAdd, true);
      }
      
      // 执行移除
      if (heroesToRemove.length > 0) {
        await batchUpdateHeroes(heroesToRemove, false);
      }
      
      // 退出多选模式
      cancelBatchSelection();
      
      if (heroesToAdd.length > 0 || heroesToRemove.length > 0) {
        alert(`已更新 ${heroesToAdd.length + heroesToRemove.length} 个英雄`);
      }
    }

    // 切换临时选中状态
    function toggleTempSelection(heroName) {
      if (tempSelection.has(heroName)) {
        tempSelection.delete(heroName);
      } else {
        tempSelection.add(heroName);
      }
      updateMultiSelectUI();
    }

    // 更新多选UI
    function updateMultiSelectUI() {
      document.querySelectorAll('.hero-item').forEach(item => {
        const heroName = item.dataset.name;
        const card = item.querySelector('.hero-card');
        
        if (isMultiSelectMode) {
          // 多选模式：显示选中状态（不移除owned类，只用样式覆盖）
          if (tempSelection.has(heroName)) {
            card.classList.add('selected-temp');
            card.style.borderColor = '#0d6efd';
            card.style.backgroundColor = '#e7f1ff';
          } else {
            card.classList.remove('selected-temp');
            // 恢复已拥有状态显示（如果已拥有）
            if (card.classList.contains('owned')) {
              card.style.borderColor = '#28a745';
              card.style.backgroundColor = '#f8fff8';
            } else {
              card.style.borderColor = '';
              card.style.backgroundColor = '';
            }
          }
        } else {
          // 正常模式：恢复原始状态
          card.classList.remove('selected-temp');
          
          // 根据是否已拥有恢复正确的样式
          if (card.classList.contains('owned')) {
            card.style.borderColor = '#28a745';
            card.style.backgroundColor = '#f8fff8';
          } else {
            card.style.borderColor = '';
            card.style.backgroundColor = '';
          }
        }
      });
      
      // 更新计数
      updateSelectedCount();
    }

    // 批量选择/取消（全选/取消按钮功能）
    async function batchSelect(select) {
      const visibleItems = getVisibleHeroes();
      
      visibleItems.forEach(item => {
        const heroName = item.dataset.name;
        if (select) {
          tempSelection.add(heroName);
        } else {
          tempSelection.delete(heroName);
        }
      });
      
      updateMultiSelectUI();
    }



    // 批量更新英雄
    async function batchUpdateHeroes(heroNames, owned) {
      try {
        const response = await fetch(`/regions/<%= region.id %>/heroes/batch-update`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ heroNames, owned })
        });
        
        const data = await response.json();
        
        if (data.success) {
          // 更新UI
          heroNames.forEach(name => {
            const item = document.querySelector(`[data-name="${name}"]`);
            if (item) {
              const card = item.querySelector('.hero-card');
              if (owned) {
                card.classList.add('owned');
              } else {
                card.classList.remove('owned');
              }
            }
          });
          updateStats(data.stats);
          updateSelectedCount();
        }
      } catch (error) {
        console.error('Error:', error);
        alert('批量操作失败，请重试');
      }
    }

    // 更新已选择计数
    function updateSelectedCount() {
      if (isMultiSelectMode) {
        // 多选模式：显示临时选择的数量
        document.getElementById('selectedCount').textContent = `已选择: ${tempSelection.size}`;
      } else {
        // 正常模式：显示已拥有的数量
        const owned = getVisibleOwnedHeroes().length;
        const total = getVisibleHeroes().length;
        document.getElementById('selectedCount').textContent = `已选择: ${owned} / ${total}`;
      }
    }

    // 处理英雄点击
    function handleHeroClick(heroName, element) {
      if (isDragging) return; // 正在拖动时不处理点击
      
      if (isMultiSelectMode) {
        toggleTempSelection(heroName);
      } else {
        toggleHero(heroName, element);
      }
    }

    // 初始化：绑定英雄网格的点击事件（使用事件委托）
    document.getElementById('heroGrid').addEventListener('click', function(e) {
      const card = e.target.closest('.hero-card');
      if (!card) return;
      
      // 如果正在拖拽，不处理点击
      if (isDragging) return;
      
      const heroName = card.closest('.hero-item').dataset.name;
      if (isMultiSelectMode) {
        toggleTempSelection(heroName);
      } else {
        toggleHero(heroName, card);
      }
    });
    
    // 初始化计数
    updateSelectedCount();
  </script>
</body>
</html>
